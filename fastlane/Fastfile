# frozen_string_literal: true

require "json"

# ───────────────────────────────────────────────────────────────────────────────
# Fastfile for MacroMark
# ───────────────────────────────────────────────────────────────────────────────
#
# Usage:
#   bundle exec fastlane release_train channel:nightly # Internal TestFlight
#   bundle exec fastlane release_train channel:weekly  # External TestFlight
#   bundle exec fastlane release_train channel:appstore # App Store Review
#   bundle exec fastlane beta           # Build + upload to TestFlight
#   bundle exec fastlane build          # Build only (CI check)
#   bundle exec fastlane test           # Run unit + UI tests
#   bundle exec fastlane release        # Full App Store release
#   bundle exec fastlane screenshots    # Capture App Store screenshots
#   bundle exec fastlane refresh_meta   # Download metadata from App Store Connect
#   bundle exec fastlane match_dev      # Refresh development certificates/profiles
#   bundle exec fastlane match_appstore # Refresh distribution certificates/profiles
# ───────────────────────────────────────────────────────────────────────────────

default_platform(:ios)

# ---------------------------------------------------------------------------
# Shared configuration
# ---------------------------------------------------------------------------

APP_SCHEME            = "MacroMark"
PROJECT_PATH          = "MacroMark.xcodeproj"
APP_IDENTIFIER        = "com.danfakkeldy.macromark"
WATCH_APP_IDENTIFIER  = "com.danfakkeldy.macromark.watchkitapp"
WIDGET_IDENTIFIER     = "com.danfakkeldy.macromark.watchkitapp.MacroMarkWidget"
TEAM_ID               = "8AXNA5B37R"
SIGNING_IDENTIFIERS   = [
  APP_IDENTIFIER,
  WATCH_APP_IDENTIFIER,
  WIDGET_IDENTIFIER
].freeze
SIGNING_TARGETS       = {
  "MacroMark" => APP_IDENTIFIER,
  "MacroMark Watch App" => WATCH_APP_IDENTIFIER,
  "MacroMarkWidgetExtension" => WIDGET_IDENTIFIER
}.freeze

def first_present(*values)
  values
    .compact
    .map(&:to_s)
    .map(&:strip)
    .find { |value| !value.empty? }
end

def parsed_ci_api_key_json
  key_json = ENV["APP_STORE_CONNECT_API_KEY_JSON"].to_s.strip
  return {} if key_json.empty?

  parsed = JSON.parse(key_json)
  parsed.is_a?(Hash) ? parsed : {}
rescue JSON::ParserError
  {}
end

def truthy_value?(value)
  %w[1 true yes].include?(value.to_s.downcase)
end

def ci_app_store_connect_api_key
  key_data = parsed_ci_api_key_json
  key_id = first_present(ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"], key_data["key_id"], key_data["keyId"], key_data["KEY_ID"])
  issuer_id = first_present(ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"], key_data["issuer_id"], key_data["issuerId"], key_data["ISSUER_ID"])
  key_content = first_present(ENV["APP_STORE_CONNECT_API_KEY_KEY"], key_data["key"], key_data["key_content"], key_data["KEY"], key_data["private_key"])
  in_house = first_present(ENV["APP_STORE_CONNECT_API_KEY_IN_HOUSE"], key_data["in_house"], key_data["inHouse"])
  return nil if key_id.nil? || issuer_id.nil? || key_content.nil?

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_content: key_content.gsub("\\n", "\n"),
    in_house: truthy_value?(in_house)
  )
end

def local_app_store_connect_api_key
  key_path = File.expand_path("api_key.json", __dir__)
  return nil unless File.exist?(key_path)

  key_data = JSON.parse(File.read(key_path))
  app_store_connect_api_key(
    key_id: key_data["key_id"],
    issuer_id: key_data["issuer_id"],
    key_content: key_data["key"],
    in_house: key_data["in_house"]
  )
end

def load_app_store_connect_api_key
  api_key = ci_app_store_connect_api_key || local_app_store_connect_api_key
  UI.important("No App Store Connect API key found. Set APP_STORE_CONNECT_API_KEY_JSON or create fastlane/api_key.json.") if api_key.nil?
  api_key
end

def release_train_channel(options)
  channel = options[:channel].to_s.strip
  channel = ENV["RELEASE_CHANNEL"].to_s.strip if channel.empty?
  channel = "nightly" if channel.empty?
  channel = "appstore" if channel == "main"

  unless %w[nightly weekly appstore].include?(channel)
    UI.user_error!("Unknown release train '#{channel}'. Expected nightly, weekly, or appstore.")
  end

  channel
end

def testflight_external_groups
  groups = ENV["TESTFLIGHT_EXTERNAL_GROUPS"].to_s
    .split(",")
    .map(&:strip)
    .reject(&:empty?)

  if groups.empty?
    UI.user_error!("Weekly external TestFlight requires TESTFLIGHT_EXTERNAL_GROUPS, for example 'External Testers'.")
  end

  groups
end

def testflight_internal_groups
  groups = ENV.fetch("TESTFLIGHT_INTERNAL_GROUPS", "Nightly")
    .split(",")
    .map(&:strip)
    .reject(&:empty?)

  groups
end

def app_store_automatic_release?
  %w[1 true yes].include?(ENV["APP_STORE_AUTOMATIC_RELEASE"].to_s.downcase)
end

def app_store_profile_name(bundle_identifier)
  first_present(
    ENV["sigh_#{bundle_identifier}_appstore_profile-name"],
    "match AppStore #{bundle_identifier}"
  )
end

def app_store_profile_mapping
  SIGNING_IDENTIFIERS.to_h do |bundle_identifier|
    [bundle_identifier, app_store_profile_name(bundle_identifier)]
  end
end

# ---------------------------------------------------------------------------
# Before All — ensure `match` is available for signing, but don't fail if
# unset. Run `fastlane match_dev` or `fastlane match_appstore` first.
# ---------------------------------------------------------------------------

platform :ios do
  before_all do
    @api_key = load_app_store_connect_api_key
  end

  def require_api_key!
    UI.user_error!("This lane needs App Store Connect access. Set APP_STORE_CONNECT_API_KEY_JSON in CI or create fastlane/api_key.json locally.") if @api_key.nil?
  end

  # ── Build-only ────────────────────────────────────────────────────────────
  desc "Build the app — no upload"
  lane :build do
    build_app(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      configuration: "Release",
      skip_archive: false,
      skip_codesigning: false,
      clean: false
    )
  end

  # ── Test ──────────────────────────────────────────────────────────────────
  desc "Run unit tests"
  lane :test do
    run_tests(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      devices: ["iPhone 17 Pro Max"]
    )
  end

  private_lane :prepare_app_store_signing do
    match(
      type: "appstore",
      app_identifier: SIGNING_IDENTIFIERS,
      readonly: true,
      api_key: @api_key
    )

    SIGNING_TARGETS.each do |target, bundle_identifier|
      update_code_signing_settings(
        use_automatic_signing: false,
        path: PROJECT_PATH,
        team_id: TEAM_ID,
        targets: [target],
        build_configurations: ["Release"],
        code_sign_identity: "Apple Distribution",
        sdk: "iphoneos*",
        profile_name: app_store_profile_name(bundle_identifier),
        bundle_identifier: bundle_identifier
      )
    end
  end

  private_lane :build_release_archive do |options|
    next_build_number = latest_testflight_build_number(
      app_identifier: APP_IDENTIFIER,
      api_key: @api_key,
      initial_build_number: 0
    ) + 1

    increment_build_number(
      xcodeproj: PROJECT_PATH,
      build_number: next_build_number.to_s
    )

    build_app(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: app_store_profile_mapping
      },
      include_symbols: true,
      include_bitcode: false,
      clean: options[:clean]
    )
  end

  private_lane :upload_testflight_train do |options|
    channel = options[:channel]
    external = options[:external]

    upload_options = {
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: false,
      changelog: "MacroMark #{channel} build uploaded via fastlane.",
      distribute_external: external
    }

    if external
      upload_options[:groups] = testflight_external_groups
      upload_options[:notify_external_testers] = true
    else
      internal_groups = testflight_internal_groups
      upload_options[:groups] = internal_groups unless internal_groups.empty?
    end

    upload_to_testflight(**upload_options)
  end

  private_lane :submit_app_store_train do
    upload_to_app_store(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: app_store_automatic_release?,
      phased_release: true,
      run_precheck_before_submit: true,
      force: true
    )
  end

  desc "Build and ship the requested release train"
  lane :release_train do |options|
    require_api_key!

    channel = release_train_channel(options)
    prepare_app_store_signing

    case channel
    when "nightly"
      build_release_archive(clean: false)
      upload_testflight_train(channel: channel, external: false)
    when "weekly"
      build_release_archive(clean: false)
      upload_testflight_train(channel: channel, external: true)
    when "appstore"
      build_release_archive(clean: true)
      submit_app_store_train
    end
  end

  # ── TestFlight beta ───────────────────────────────────────────────────────
  desc "Build and upload a TestFlight beta for the requested train"
  lane :beta do |options|
    require_api_key!

    channel = release_train_channel(options)
    UI.user_error!("The beta lane only supports nightly or weekly.") if channel == "appstore"

    prepare_app_store_signing
    build_release_archive(clean: false)
    upload_testflight_train(
      channel: channel,
      external: channel == "weekly"
    )
  end

  # ── Release (App Store submission) ────────────────────────────────────────
  desc "Build, upload, and submit to App Store Review"
  lane :release do
    release_train(channel: "appstore")
  end

  # ── Screenshots ───────────────────────────────────────────────────────────
  desc "Capture App Store screenshots with snapshot"
  lane :screenshots do
    capture_screenshots(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      devices: [
        "iPhone 17 Pro Max",
        "iPhone 16e"
      ],
      languages: ["en-US"],
      include_original_screenshots: false,
      erase_simulator: true,
      localize_simulator: true,
      reinstall_app: true,
      clear_previous_screenshots: true
    )

    # Optionally download existing App Store metadata so screenshots
    # are placed alongside the right locale folders.
    # deliver(overwrite_screenshots: false, ignore_language_directory_validation: true)
  end

  # ── Metadata ──────────────────────────────────────────────────────────────
  desc "Download existing App Store metadata for editing locally"
  lane :refresh_meta do
    deliver(
      overwrite_screenshots: false,
      ignore_language_directory_validation: true,
      force: true
    )
  end

  # ── Code signing (Match) ──────────────────────────────────────────────────
  desc "Refresh development certificates & provisioning profiles"
  lane :match_dev do
    match(
      type: "development",
      app_identifier: SIGNING_IDENTIFIERS,
      readonly: true
    )
  end

  desc "Refresh App Store distribution certificates & provisioning profiles"
  lane :match_appstore do
    match(
      type: "appstore",
      app_identifier: SIGNING_IDENTIFIERS,
      readonly: true
    )
  end
end
