# frozen_string_literal: true

# ───────────────────────────────────────────────────────────────────────────────
# Fastfile for MacroMark
# ───────────────────────────────────────────────────────────────────────────────
#
# Usage:
#   bundle exec fastlane beta           # Build + upload to TestFlight
#   bundle exec fastlane build          # Build only (CI check)
#   bundle exec fastlane test           # Run unit + UI tests
#   bundle exec fastlane release        # Full TestFlight release (optionally submit)
#   bundle exec fastlane screenshots    # Capture App Store screenshots
#   bundle exec fastlane upload_screenshots # Upload screenshots only
#   bundle exec fastlane screenshot_release # Capture + upload screenshots
#   bundle exec fastlane refresh_meta   # Download metadata from App Store Connect
#   bundle exec fastlane match_dev      # Refresh development certificates/profiles
#   bundle exec fastlane match_appstore # Refresh distribution certificates/profiles
# ───────────────────────────────────────────────────────────────────────────────

default_platform(:ios)

# ---------------------------------------------------------------------------
# Shared configuration
# ---------------------------------------------------------------------------

APP_SCHEME            = "MacroMark"
PROJECT_PATH          = "MacroMark.xcodeproj"
APP_IDENTIFIER        = "com.danfakkeldy.macromark"
TEAM_ID               = "8AXNA5B37R"

def load_app_store_connect_api_key
  require "json"

  key_path = File.expand_path("api_key.json", __dir__)
  unless File.exist?(key_path)
    UI.important("No fastlane/api_key.json found. App Store Connect lanes are unavailable until it is copied from Echo or recreated.")
    return nil
  end

  key_data = JSON.parse(File.read(key_path))
  app_store_connect_api_key(
    key_id: key_data["key_id"],
    issuer_id: key_data["issuer_id"],
    key_content: key_data["key"],
    in_house: key_data["in_house"]
  )
end

# ---------------------------------------------------------------------------
# Before All — ensure `match` is available for signing, but don't fail if
# unset. Run `fastlane match_dev` or `fastlane match_appstore` first.
# ---------------------------------------------------------------------------

platform :ios do
  before_all do
    @api_key = load_app_store_connect_api_key
  end

  def require_api_key!
    UI.user_error!("This lane needs App Store Connect access. Copy Echo's git-ignored fastlane/api_key.json into MacroMark/fastlane/ and re-run.") if @api_key.nil?
  end

  # ── Build-only ────────────────────────────────────────────────────────────
  desc "Build the app — no upload"
  lane :build do
    build_app(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      configuration: "Release",
      skip_archive: false,
      skip_codesigning: false,
      clean: false
    )
  end

  # ── Test ──────────────────────────────────────────────────────────────────
  desc "Run unit tests"
  lane :test do
    run_tests(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      devices: ["iPhone 17 Pro Max"]
    )
  end

  # ── TestFlight beta ───────────────────────────────────────────────────────
  desc "Build and upload a new TestFlight beta"
  lane :beta do
    require_api_key!

    increment_build_number(
      xcodeproj: PROJECT_PATH
    )

    build_app(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      include_symbols: true,
      include_bitcode: false,
      clean: false
    )

    upload_to_testflight(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: false,
      changelog: "Beta build uploaded via fastlane.",
      distribute_external: false
    )
  end

  # ── Release (TestFlight + optional submission) ────────────────────────────
  desc "Build, upload to TestFlight, and optionally submit for App Store review"
  lane :release do
    require_api_key!

    increment_build_number(
      xcodeproj: PROJECT_PATH
    )

    build_app(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      include_symbols: true,
      include_bitcode: false,
      clean: true
    )

    upload_to_testflight(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: false,
      distribute_external: true
    )

    # Submit for review only when explicitly confirmed via the terminal
    if UI.confirm("Submit this build for App Store Review?")
      deliver(
        api_key: @api_key,
        submit_for_review: true,
        automatic_release: false,
        phased_release: true,
        force: true
      )
    end
  end

  # ── Screenshots ───────────────────────────────────────────────────────────
  desc "Capture App Store screenshots with snapshot"
  lane :screenshots do
    capture_screenshots(
      project: PROJECT_PATH,
      scheme: APP_SCHEME,
      devices: [
        "iPhone 17 Pro Max",
        "iPhone 17e",
        "iPad Pro 13-inch (M5)"
      ],
      languages: ["en-US"],
      launch_arguments: ["--screenshot-mode"],
      xcargs: "-parallel-testing-enabled NO",
      output_directory: "fastlane/screenshots",
      only_testing: ["MacroMarkUITests/MacroMarkScreenshotUITests/testAppStoreScreenshots"],
      erase_simulator: true,
      localize_simulator: true,
      reinstall_app: true,
      clear_previous_screenshots: true,
      override_status_bar: true,
      skip_open_summary: true,
      concurrent_simulators: false
    )
  end

  desc "Upload generated screenshots without uploading metadata or a binary"
  lane :upload_screenshots do
    require_api_key!

    upload_to_app_store(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Capture and upload App Store screenshots"
  lane :screenshot_release do
    screenshots
    upload_screenshots
  end

  # ── Metadata ──────────────────────────────────────────────────────────────
  desc "Download existing App Store metadata for editing locally"
  lane :refresh_meta do
    require_api_key!

    deliver(
      api_key: @api_key,
      overwrite_screenshots: false,
      ignore_language_directory_validation: true,
      force: true
    )
  end

  desc "Upload App Store metadata without uploading a binary or screenshots"
  lane :upload_metadata do
    require_api_key!

    upload_to_app_store(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Verify App Store Connect API key configuration"
  lane :test_auth do
    require_api_key!
    UI.success("App Store Connect API key loaded successfully.")
  end

  # ── Code signing (Match) ──────────────────────────────────────────────────
  desc "Refresh development certificates & provisioning profiles"
  lane :match_dev do
    match(
      type: "development",
      app_identifier: [
        "com.danfakkeldy.macromark",
        "com.danfakkeldy.macromark.watchkitapp",
        "com.danfakkeldy.macromark.watchkitapp.MacroMarkWidget"
      ],
      readonly: true
    )
  end

  desc "Refresh App Store distribution certificates & provisioning profiles"
  lane :match_appstore do
    match(
      type: "appstore",
      app_identifier: [
        "com.danfakkeldy.macromark",
        "com.danfakkeldy.macromark.watchkitapp",
        "com.danfakkeldy.macromark.watchkitapp.MacroMarkWidget"
      ],
      readonly: true
    )
  end
end
